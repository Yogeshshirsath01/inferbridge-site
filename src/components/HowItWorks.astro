---
/**
 * How it works — 4 steps, single column, thin left border in --accent-muted.
 * Design doc §3 + copy doc §5.
 */
import Container from "./Container.astro";
import Section from "./Section.astro";
import TextBlock from "./TextBlock.astro";
---

<Section background="raised">
  <Container>
    <TextBlock align="center">
      <h2>Four steps. Five minutes.</h2>
    </TextBlock>

    <ol class="steps">
      <li class="step">
        <span class="num" aria-hidden="true">01</span>
        <div class="copy">
          <h3>Register</h3>
          <p>
            POST to <code>/v1/users</code> with your email. You get an API
            key starting with <code>ib_</code>. Shown once, stored as a
            SHA-256 hash.
          </p>
        </div>
      </li>

      <li class="step">
        <span class="num" aria-hidden="true">02</span>
        <div class="copy">
          <h3>Add your provider keys</h3>
          <p>
            BYOK means you bring your existing OpenAI, Anthropic,
            Together, or Sarvam keys. We Fernet-encrypt them at rest and
            never touch your billing.
          </p>
        </div>
      </li>

      <li class="step">
        <span class="num" aria-hidden="true">03</span>
        <div class="copy">
          <h3>Change your base URL</h3>
          <p>
            Two lines in your existing code. Any language, any framework.
            If it talks to OpenAI, it talks to InferBridge.
          </p>
        </div>
      </li>

      <li class="step">
        <span class="num" aria-hidden="true">04</span>
        <div class="copy">
          <h3>Ship</h3>
          <p>
            Monitor cost and latency at <code>/v1/stats</code>. Fallback
            and caching work automatically. Revert the two lines if
            anything breaks.
          </p>
        </div>
      </li>
    </ol>
  </Container>
</Section>

<style>
  h2 {
    margin-bottom: 56px;
  }

  .steps {
    list-style: none;
    max-width: 720px;
    margin-inline: auto;
    border-inline-start: 1px solid var(--accent-muted);
    padding-inline-start: 32px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .step {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 20px;
    align-items: baseline;
  }

  .num {
    font-family: var(--font-mono);
    font-size: var(--fs-caption);
    font-weight: 500;
    color: var(--accent);
    letter-spacing: var(--ls-caption);
  }

  .step h3 {
    margin-bottom: 8px;
  }

  .step p {
    color: var(--gray-300);
    font-size: var(--fs-body);
    line-height: var(--lh-body-sm);
  }

  .step code {
    background-color: var(--gray-800);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--accent);
    font-size: 0.85em;
  }

  @media (max-width: 768px) {
    .steps {
      padding-inline-start: 20px;
      gap: 28px;
    }

    .step {
      grid-template-columns: 36px 1fr;
      gap: 12px;
    }
  }
</style>
