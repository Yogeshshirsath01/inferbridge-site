---
/**
 * Pricing — two tiers, Free and Enterprise.
 *
 * Earlier drafts had two paid SaaS rungs between them; those were
 * removed once the actual revenue path became clear (free
 * developers → custom enterprise contracts, with no SaaS step in
 * between). Layout still mirrors the original three-card pattern,
 * just narrowed to two columns.
 */
import Container from "./Container.astro";
import Section from "./Section.astro";
import TextBlock from "./TextBlock.astro";

const enterpriseMailto =
  "mailto:hello@inferbridge.dev?subject=InferBridge%20Enterprise%20Inquiry";
---

<Section background="raised">
  <Container>
    <TextBlock align="center">
      <h2>Honest pricing. No markup. Ever.</h2>
      <p class="intro">
        Start free. Bring your own keys. Pay nothing until you need
        enterprise features.
      </p>
    </TextBlock>

    <div class="tiers">
      <article class="tier">
        <h3>Free</h3>
        <p class="price"><span class="amount">$0</span> / month</p>
        <p class="subline">No credit card required.</p>

        <ul class="features" aria-label="Free tier features">
          <li>10 providers (global, India, EU)</li>
          <li>Unlimited BYOK</li>
          <li>All routing tiers (cheap / balanced / premium)</li>
          <li>Streaming + caching</li>
          <li>DPDP audit export (signed JSON + PDF)</li>
          <li>Residency-aware routing</li>
          <li>Per-request observability (<code>/v1/stats</code>, <code>/v1/logs</code>)</li>
          <li>Rate limiting: 60 rpm / 100k tpm</li>
          <li>30-day log retention</li>
        </ul>

        <a class="tier-cta tier-cta-primary" href="/docs/getting-started/"
          >Get started free</a
        >
      </article>

      <article class="tier tier-enterprise">
        <h3>Enterprise</h3>
        <p class="price"><span class="amount">Custom</span></p>
        <p class="subline">For teams with compliance requirements.</p>
        <p class="value-prop">
          Custom residency policies, SLA, dedicated support, and
          GST-compliant invoices.
        </p>

        <ul class="features" aria-label="Enterprise tier features">
          <li>Everything in Free</li>
          <li>Custom residency policies</li>
          <li>SLA guarantee</li>
          <li>Dedicated support</li>
          <li>GST-compliant invoices (India)</li>
          <li>Extended log retention</li>
          <li>Priority rate limits</li>
        </ul>

        <a class="tier-cta tier-cta-secondary" href={enterpriseMailto}
          >Contact us</a
        >
      </article>
    </div>
  </Container>
</Section>

<style>
  h2 {
    margin-bottom: 12px;
  }

  .intro {
    color: var(--gray-300);
    font-size: var(--fs-body);
    max-width: 600px;
    margin-inline: auto;
    margin-bottom: 56px;
  }

  .tiers {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    max-width: 880px;
    margin-inline: auto;
  }

  .tier {
    background-color: var(--gray-800);
    border: 1px solid var(--gray-700);
    border-radius: 12px;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Subtle accent border draws the eye without raising visual weight
   * past the Free card. Background stays gray-800 so contrast on body
   * text is identical to the Free card. */
  .tier-enterprise {
    border-color: var(--accent);
  }

  .tier h3 {
    font-size: 1.5rem;
    margin: 0;
  }

  .price {
    color: var(--gray-300);
    font-size: var(--fs-body-sm);
    margin: 0;
  }

  .amount {
    color: var(--gray-50);
    font-weight: 600;
    font-size: 1.75rem;
    margin-right: 6px;
  }

  .subline {
    color: var(--gray-300);
    font-size: var(--fs-body-sm);
    margin: 0;
  }

  .value-prop {
    color: var(--gray-200);
    font-size: 1rem;
    line-height: var(--lh-body-sm);
    margin: 0;
  }

  .features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex-grow: 1;
  }

  .features li {
    color: var(--gray-300);
    font-size: var(--fs-body-sm);
    line-height: var(--lh-body-sm);
    padding-inline-start: 22px;
    position: relative;
  }

  /* Checkmark in --accent so the tick reads as positive without
   * needing a third color. ::before keeps the bullet out of the DOM
   * and out of the screen-reader announcement (the surrounding ul
   * already labels the items as features). */
  .features li::before {
    content: "✓";
    position: absolute;
    inset-inline-start: 0;
    color: var(--accent-text);
    font-weight: 600;
  }

  .features code {
    background-color: var(--gray-900);
    padding: 1px 5px;
    border-radius: 4px;
    color: var(--accent-text);
    font-size: 0.92em;
  }

  .tier-cta {
    display: inline-block;
    padding: 10px 20px;
    border-radius: 8px;
    /* 19px + 700 → AA Large (3:1); gray-50 on accent is 4.04:1. See
     * Hero .cta-primary for the same constraint. */
    font-weight: 700;
    font-size: 1.1875rem;
    text-align: center;
    transition:
      background-color var(--transition),
      color var(--transition),
      border-color var(--transition);
  }

  .tier-cta-primary {
    background-color: var(--accent);
    color: var(--gray-50);
  }

  .tier-cta-primary:hover {
    background-color: #6e7bf5;
    text-decoration: none;
  }

  /* Outlined secondary: transparent background + accent border/text,
   * filled on hover. Mirrors the standard "secondary CTA" pattern from
   * design system docs but kept local so a Hero-CTA tweak doesn't
   * cascade into the pricing surface. */
  .tier-cta-secondary {
    background-color: transparent;
    color: var(--accent-text);
    border: 1px solid var(--accent);
  }

  .tier-cta-secondary:hover {
    background-color: var(--accent);
    color: var(--gray-50);
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .tiers {
      grid-template-columns: 1fr;
    }
  }
</style>
