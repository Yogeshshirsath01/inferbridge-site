---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/Container.astro";
import Footer from "../../components/Footer.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);

const dateFmt = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});

const title = "Blog — InferBridge";
const description =
  "Technical articles on LLM routing, cost optimisation, and data residency from the InferBridge team.";
const canonical = "https://www.inferbridge.dev/blog/";
---

<Layout title={title} description={description} canonical={canonical}>
  <main class="page">
    <Container>
      <header class="masthead">
        <a class="brandmark" href="/" aria-label="InferBridge home">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 38 32"
            width="32"
            height="27"
            role="img"
            aria-hidden="true"
          >
            <rect x="3" y="3" width="6" height="26" rx="1.5" fill="#5b6af0"></rect>
            <rect x="16" y="3" width="5" height="26" rx="1.5" fill="#5b6af0"></rect>
            <path d="M21 3 H27 a6.5 6.5 0 0 1 0 13 H21 z" fill="#5b6af0"></path>
            <path d="M21 16 H28 a6.5 6.5 0 0 1 0 13 H21 z" fill="#5b6af0"></path>
          </svg>
          <span class="wordmark">InferBridge</span>
        </a>
      </header>

      <section class="intro">
        <h1>Blog</h1>
        <p class="lede">{description}</p>
      </section>

      {
        posts.length === 0 ? (
          <p class="empty">No posts yet.</p>
        ) : (
          <ul class="posts">
            {posts.map((post) => (
              <li class="post">
                <a class="post-link" href={`/blog/${post.id}/`}>
                  <h2 class="post-title">{post.data.title}</h2>
                </a>
                <p class="meta">
                  <time datetime={post.data.publishedAt.toISOString()}>
                    {dateFmt.format(post.data.publishedAt)}
                  </time>
                </p>
                <p class="post-desc">{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <ul class="tags" aria-label="Tags">
                    {post.data.tags.map((tag) => (
                      <li class="tag">{tag}</li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        )
      }
    </Container>
  </main>
  <Footer />
</Layout>

<style>
  .page {
    padding-block: 48px 96px;
    background-color: var(--gray-950);
    min-height: 100vh;
  }

  .masthead {
    margin-bottom: 64px;
  }

  .brandmark {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--accent);
    text-decoration: none;
    line-height: 0;
  }

  .wordmark {
    color: var(--gray-50);
    font-weight: 600;
    font-size: 1.0625rem;
    line-height: 1;
  }

  .brandmark:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 6px;
    border-radius: 4px;
  }

  .intro {
    max-width: var(--text-max);
    margin-bottom: 64px;
  }

  .lede {
    color: var(--gray-300);
    font-size: 1.125rem;
    line-height: 1.55;
    margin-top: 16px;
    max-width: 640px;
  }

  .posts {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 40px;
    max-width: var(--text-max);
  }

  .post {
    border-block-start: 1px solid var(--gray-700);
    padding-block-start: 28px;
  }

  .post-link {
    color: inherit;
  }

  .post-link:hover {
    text-decoration: none;
  }

  .post-link:hover .post-title {
    color: var(--accent-text);
  }

  .post-title {
    font-size: 1.5rem;
    line-height: 1.3;
    margin-bottom: 8px;
    transition: color var(--transition);
  }

  .meta {
    color: var(--gray-300);
    font-size: var(--fs-caption);
    letter-spacing: var(--ls-caption);
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .post-desc {
    color: var(--gray-300);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    margin-bottom: 16px;
    max-width: 640px;
  }

  .tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag {
    background-color: var(--accent-dim);
    color: var(--accent-text);
    font-family: var(--font-mono);
    font-size: var(--fs-caption);
    letter-spacing: var(--ls-caption);
    padding: 4px 10px;
    border-radius: 999px;
  }

  .empty {
    color: var(--gray-300);
  }
</style>
