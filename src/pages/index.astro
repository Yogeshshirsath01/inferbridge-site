---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import CodeMigration from "../components/CodeMigration.astro";
import RoutingLogic from "../components/RoutingLogic.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Providers from "../components/Providers.astro";
import Pricing from "../components/Pricing.astro";
import Faq from "../components/Faq.astro";
import Waitlist from "../components/Waitlist.astro";
import Footer from "../components/Footer.astro";

const title = "InferBridge — One API for every LLM";
const description =
  "Drop-in OpenAI-compatible gateway for OpenAI, Anthropic, Together, Sarvam, and self-hosted models. BYOK, zero markup. Two lines to migrate.";

const softwareApplicationLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "InferBridge",
  url: "https://www.inferbridge.dev",
  description:
    "One OpenAI-compatible API for every LLM — global, Indian, and EU providers with fallback, caching, and per-request observability.",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Web",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
};

const organizationLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "InferBridge",
  url: "https://www.inferbridge.dev",
  contactPoint: {
    "@type": "ContactPoint",
    email: "hello@inferbridge.dev",
  },
};
---

<Layout title={title} description={description}>
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify(softwareApplicationLd)}
  />
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify(organizationLd)}
  />
  <main>
    <Hero />
    <CodeMigration />
    <RoutingLogic />
    <HowItWorks />
    <Providers />
    <Pricing />
    <Faq />
    <Waitlist />
  </main>
  <Footer />
</Layout>

<script>
  import "../scripts/copy-code";
</script>
